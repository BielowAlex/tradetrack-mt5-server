# Redis (optional; default in code: redis://localhost:6379/0)
# REDIS_URL=redis://localhost:6379/0

# Number of queues (workers). For 3 workers set 3.
# MT5_QUEUES_NUM=3

# Path to MT5 for each worker (скрипт restart.ps1 підставляє MT5_PATH_0, MT5_PATH_1, … у відповідний воркер)
# MT5_PATH_0=C:\mt5-instance1\terminal64.exe
# MT5_PATH_1=C:\mt5-instance2\terminal64.exe
# MT5_PATH_2=C:\mt5-instance3\terminal64.exe

# Optional: command to start extra server in own window (e.g. Caddy). Run after workers.
# EXTRA_SERVER_CMD=Set-Location C:\m5-app\caddy; caddy run
